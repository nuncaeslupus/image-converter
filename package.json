{
  "name": "image-converter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Free, browser-based raster-to-SVG converter. Everything runs client-side.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "preview": "vite preview",
    "og": "node scripts/generate-og.mjs",
    "test": "vitest run --exclude tests/build.test.ts",
    "test:watch": "vitest --exclude tests/build.test.ts",
    "test:build": "vitest run tests/build.test.ts",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\" \"*.{json,js,ts}\" \"index.html\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\" \"*.{json,js,ts}\" \"index.html\"",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@fontsource/onest": "^5.3.0",
    "@preact/preset-vite": "^2.10.5",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "image-size": "^2.0.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
